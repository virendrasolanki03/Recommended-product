# ─────────────────────────────────────────────
# Shopify App Proxy — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Port the Express server listens on
PORT=3000

# Your Shopify app's API Secret (found in Partners Dashboard → App → API credentials)
# This is used to verify HMAC signatures on incoming App Proxy requests.
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_secret_here

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300
